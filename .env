# ============================================================
# AgentOS — Complete Free Tier Configuration
# ============================================================

# ---- CORE LLM (ALL FREE) ----
GROQ_API_KEY=gsk_your_groq_key_here
# Get free at: https://console.groq.com (no credit card)

# ---- HUGGINGFACE (FREE TIER) ----
HF_TOKEN=hf_your_hf_token_here
# Get free at: https://huggingface.co/settings/tokens

# ---- TELEGRAM (FREE, REPLACES WHATSAPP) ----
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# Create free bot: message @BotFather on Telegram

# ---- GITHUB (FREE PERSONAL ACCESS TOKEN) ----
GITHUB_TOKEN=ghp_your_github_token_here
# Get free at: github.com/settings/tokens

# ---- NOTION (FREE INTEGRATION TOKEN) ----
NOTION_API_KEY=secret_your_notion_key_here
# Get free at: notion.so/my-integrations

# ---- COPERNICUS/SENTINEL (FREE SATELLITE DATA) ----
COPERNICUS_CLIENT_ID=your_copernicus_id
COPERNICUS_CLIENT_SECRET=your_copernicus_secret
# Register free at: dataspace.copernicus.eu

# ---- DATABASES (ALL SELF-HOSTED = FREE) ----
POSTGRES_URL=postgresql://agentos:agentos@postgres:5432/agentos
REDIS_URL=redis://redis:6379/0
CHROMA_HOST=chromadb
CHROMA_PORT=8000
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ---- AGENTOS INTERNAL ----
AGENTOSINTERNAL_SERVICE_TOKEN=your_random_256bit_secret_here
AGENTOS_JWT_SECRET=your_random_256bit_jwt_secret_here

# ---- NO-KEY FREE APIs (JUST DOCUMENT THE URLS) ----
OPEN_METEO_URL=https://api.open-meteo.com/v1/forecast
DATA_GOV_IN_URL=https://api.data.gov.in/resource
OPENFDA_URL=https://api.fda.gov

# ---- OPTIONAL: LOCAL OLLAMA FALLBACK ----
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
