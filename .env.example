# --------------------------------------------------------
# ORALLEX ENVIRONMENT CONFIGURATION (.env.example)
# --------------------------------------------------------

# LLM Providers
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxx
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxx

# AgentOS Shared Infrastructure
REDIS_URL=redis://redis:6379/0
POSTGRES_URL=postgresql+asyncpg://agentos:agentos_password@postgres:5432/agentos_shared
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# MinIO (S3 Compatible Storage for Audio)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=minio_secret_key

# External Integrations
NOTION_API_KEY=secret_notion_mock
CONFLUENCE_DOMAIN=yourcompany
CONFLUENCE_USERNAME=user@yourcompany.com
CONFLUENCE_API_TOKEN=mock_confluence_token

# Application Settings
LOG_LEVEL=INFO
ENVIRONMENT=development
